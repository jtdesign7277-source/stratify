{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/market-summary?period=premarket",
      "schedule": "25 13 * * 1-5"
    },
    {
      "path": "/api/cron/market-summary?period=close",
      "schedule": "5 20 * * 1-5"
    },
    {
      "path": "/api/warm-cache",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/warm-warroom?batch=scans",
      "schedule": "0 13,15,17,19,21 * * 1-5"
    },
    {
      "path": "/api/cron/warm-warroom?batch=transcripts",
      "schedule": "5 13,21 * * 1-5"
    },
    {
      "path": "/api/cron/warm-warroom?batch=transcripts2",
      "schedule": "10 13,21 * * 1-5"
    }
  ]
}
