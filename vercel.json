{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/market-summary?period=premarket",
      "schedule": "25 13 * * 1-5"
    },
    {
      "path": "/api/cron/market-summary?period=close",
      "schedule": "5 20 * * 1-5"
    },
    {
      "path": "/api/warm-cache",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/warm-warroom?batch=scans",
      "schedule": "0 13,14,15,16,17,18,19,20,21 * * 1-5"
    },
    {
      "path": "/api/cron/warm-warroom?batch=transcripts",
      "schedule": "5 13,17,21 * * 1-5"
    },
    {
      "path": "/api/cron/warm-warroom?batch=transcripts2",
      "schedule": "10 13,17,21 * * 1-5"
    },
    {
      "path": "/api/trends",
      "schedule": "*/10 13-21 * * 1-5"
    },
    {
      "path": "/api/cron/community-bot",
      "schedule": "*/10 6-16 * * 1-5"
    },
    {
      "path": "/api/x-post?type=morning-briefing&post=true",
      "schedule": "30 13 * * 1-5"
    },
    {
      "path": "/api/x-post?type=technical-setup&post=true",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/x-post?type=top-movers&post=true",
      "schedule": "0 15 * * 1-5"
    },
    {
      "path": "/api/x-post?type=technical-setup&post=true",
      "schedule": "0 16 * * 1-5"
    },
    {
      "path": "/api/x-post?type=power-hour&post=true",
      "schedule": "0 20 * * 1-5"
    },
    {
      "path": "/api/x-post?type=market-recap&post=true",
      "schedule": "15 21 * * 1-5"
    },
    {
      "path": "/api/x-post?type=afterhours-movers&post=true",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/x-post?type=technical-setup&post=true",
      "schedule": "0 23 * * 1-5"
    },
    {
      "path": "/api/x-post?type=weekend-watchlist&post=true",
      "schedule": "0 15 * * 6"
    },
    {
      "path": "/api/feeds-warm",
      "schedule": "0 12 * * 0"
    }
  ]
}
