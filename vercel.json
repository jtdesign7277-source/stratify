{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/warm-cache",
            "schedule": "* * * * *"
        },
        {
            "path": "/api/cron/warm-warroom?batch=scans",
            "schedule": "0 13,14,15,16,17,18,19,20,21 * * 1-5"
        },
        {
            "path": "/api/cron/warm-warroom?batch=transcripts",
            "schedule": "5 13,17,21 * * 1-5"
        },
        {
            "path": "/api/cron/warm-warroom?batch=transcripts2",
            "schedule": "10 13,17,21 * * 1-5"
        },
        {
            "path": "/api/trends",
            "schedule": "*/10 13-21 * * 1-5"
        },
        {
            "path": "/api/cron/community-bot",
            "schedule": "*/10 6-16 * * 1-5"
        },
        {
            "path": "/api/feeds?feed=Earnings",
            "schedule": "0 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=Momentum",
            "schedule": "1 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=Trending",
            "schedule": "2 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=Options",
            "schedule": "3 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=Macro",
            "schedule": "4 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=Sentiment",
            "schedule": "5 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=Bitcoin",
            "schedule": "6 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=AI",
            "schedule": "7 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=Trump",
            "schedule": "8 12 * * 0"
        },
        {
            "path": "/api/feeds?feed=MemeStocks",
            "schedule": "9 12 * * 0"
        },
        {
            "path": "/api/x-bot-v2?type=market-open",
            "schedule": "35 13 * * 1-5"
        },
        {
            "path": "/api/x-bot-v2?type=mag7",
            "schedule": "0 15 * * 1-5"
        },
        {
            "path": "/api/x-bot-v2?type=breaking",
            "schedule": "30 16 * * 1-5"
        },
        {
            "path": "/api/x-bot-v2?type=top-movers",
            "schedule": "0 17 * * 1-5"
        },
        {
            "path": "/api/x-bot-v2?type=crypto",
            "schedule": "0 19 * * 0-6"
        },
        {
            "path": "/api/x-bot-v2?type=market-close",
            "schedule": "5 20 * * 1-5"
        },
        {
            "path": "/api/x-bot-v2?type=breaking",
            "schedule": "0 23 * * 1-5"
        },
        {
            "path": "/api/settle-sports-bets",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/x-bot-v2?type=trump-watch",
            "schedule": "*/30 13-22 * * *"
        },
        {
            "path": "/api/x-bot-v2?type=engagement",
            "schedule": "*/30 13-23 * * *"
        },
        {
            "path": "/api/x-bot-v2?type=thought-leader",
            "schedule": "0 14 * * 1-5"
        },
        {
            "path": "/api/x-bot-v2?type=hot-take",
            "schedule": "0 18 * * 1-5"
        },
        {
            "path": "/api/x-bot-v2?type=funny",
            "schedule": "0 22 * * *"
        },
        {
            "path": "/api/x-bot-v2?type=sentinel-pnl",
            "schedule": "15 21 * * 1-5"
        },
        {
            "path": "/api/cron/market-summary?period=close",
            "schedule": "5 20 * * 1-5"
        },
        {
            "path": "/api/sentinel/heartbeat",
            "schedule": "* 14-21 * * 1-5"
        },
                {
                                "path": "/api/sentinel/heartbeat-crypto",
                                "schedule": "* * * * *"
                },
        {
            "path": "/api/sentinel/polymarket-heartbeat",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/sentinel/learn",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/sentinel/fill-labels",
            "schedule": "*/15 * * * *"
        },
        {
            "path": "/api/sentinel/autoresearch?iterations=2&tag=auto",
            "schedule": "*/2 * * * *"
        }
    ]
}
